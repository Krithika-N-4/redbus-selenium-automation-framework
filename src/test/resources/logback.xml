<configuration>
	
	<appender name = "FILE" class = "ch.qos.logback.core.FileAppender">
		
		<file>logs/testlogs.log</file>
		<append>true</append>
		
		<encoder>
			<pattern>%d{dd-MM-yyyy HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
		</encoder>
	
	</appender>
	
	<logger name = "org.testng" level="off">
		<appender-ref ref="FILE"/>
	</logger>
	
	<root level="info">
		<appender-ref ref="FILE"/>
	</root>

</configuration>